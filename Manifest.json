{
  "manifest_version": 3,
  "name": "Epstein & Associates Blocker",
  "version": "1.0",
  "description": "Blocks websites and pages that mention individuals from the Epstein files.",
  "permissions": [
    "declarativeNetRequest",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["blockpage.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {}
}
